<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_primary"
    android:orientation="vertical">

    <!-- Player area (portrait mode, 16:9) -->
    <FrameLayout
        android:id="@+id/fl_live_player"
        android:layout_width="match_parent"
        android:layout_height="210dp"
        android:background="@color/color_FF000000">

        <!-- Player view injected here at runtime -->

        <!-- Channel info overlay (top) -->
        <LinearLayout
            android:id="@+id/ll_channel_info_bar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/gradient_top_dark"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp">

            <ImageView
                android:id="@+id/iv_channel_logo"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:scaleType="centerInside" />

            <TextView
                android:id="@+id/tv_channel_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:layout_weight="1"
                android:textColor="@color/color_text_white"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_live_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_text_white"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Bottom controls overlay -->
        <LinearLayout
            android:id="@+id/ll_live_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_bottom_dark"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="20dp"
            android:paddingBottom="8dp">

            <ImageView
                android:id="@+id/iv_live_play_pause"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_pause"
                android:tint="@color/color_text_white" />

            <ImageView
                android:id="@+id/iv_live_retry"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_refresh"
                android:tint="@color/color_text_white" />

            <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

            <!-- Route indicator -->
            <LinearLayout
                android:id="@+id/ll_route_switch"
                android:layout_width="wrap_content"
                android:layout_height="28dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:id="@+id/iv_route_prev"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_left"
                    android:tint="@color/color_text_white" />

                <TextView
                    android:id="@+id/tv_route_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    android:text="线路1/1"
                    android:textColor="@color/color_text_white"
                    android:textSize="12sp" />

                <ImageView
                    android:id="@+id/iv_route_next"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_chevron_right"
                    android:tint="@color/color_text_white" />
            </LinearLayout>

            <View android:layout_width="12dp" android:layout_height="1dp" />

            <!-- Cast + Settings -->
            <ImageView
                android:id="@+id/iv_live_cast"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_cast"
                android:tint="@color/color_text_white" />

            <ImageView
                android:id="@+id/iv_live_settings"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_settings_outlined"
                android:tint="@color/color_text_white" />

            <!-- Fullscreen -->
            <ImageView
                android:id="@+id/iv_live_fullscreen"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_marginStart="10dp"
                android:src="@drawable/ic_fullscreen"
                android:tint="@color/color_text_white" />
        </LinearLayout>

        <!-- Loading -->
        <ProgressBar
            android:id="@+id/pb_live_loading"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/color_text_white"
            android:visibility="gone" />
    </FrameLayout>

    <!-- EPG current program bar -->
    <LinearLayout
        android:id="@+id/ll_epg_bar"
        android:layout_width="match_parent"
        android:layout_height="38dp"
        android:background="@color/color_bg_secondary"
        android:gravity="center_vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:visibility="visible">

        <TextView
            android:id="@+id/tv_epg_current"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/color_text_secondary"
            android:textSize="12sp" />

        <TextView
            android:id="@+id/tv_epg_more"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="节目单 ›"
            android:textColor="@color/color_primary"
            android:textSize="12sp" />
    </LinearLayout>

    <View android:layout_width="match_parent" android:layout_height="1dp"
        android:background="@color/color_divider" />

    <!-- Channel picker area: left groups + right channels -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Left: group list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_live_groups"
            android:layout_width="90dp"
            android:layout_height="match_parent"
            android:background="@color/color_bg_secondary"
            android:scrollbars="none" />

        <View android:layout_width="1dp" android:layout_height="match_parent"
            android:background="@color/color_divider" />

        <!-- Right: channel list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_live_channels"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:scrollbars="none" />
    </LinearLayout>

</LinearLayout>
