<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_secondary"
    android:orientation="vertical">

    <!-- Top bar: source selector + search + icons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@color/color_bg_primary"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="12dp"
        android:paddingEnd="12dp">

        <!-- Source selector -->
        <LinearLayout
            android:id="@+id/ll_source_selector"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="4dp"
            android:paddingEnd="2dp">

            <TextView
                android:id="@+id/tv_source_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:ellipsize="end"
                android:maxWidth="80dp"
                android:maxLines="1"
                android:text="@string/app_name"
                android:textColor="@color/color_text_primary"
                android:textSize="14sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="2dp"
                android:src="@drawable/ic_arrow_down"
                android:tint="@color/color_text_secondary" />
        </LinearLayout>

        <!-- Search bar (clickable, goes to search activity) -->
        <LinearLayout
            android:id="@+id/ll_search_bar"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="10dp"
            android:layout_weight="1"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="8dp">

            <ImageView
                android:layout_width="18dp"
                android:layout_height="18dp"
                android:src="@drawable/ic_search"
                android:tint="@color/color_text_hint" />

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="@string/search_hint"
                android:textColor="@color/color_text_hint"
                android:textSize="13sp" />
        </LinearLayout>

        <!-- Collect icon -->
        <ImageView
            android:id="@+id/iv_collect"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:padding="6dp"
            android:src="@drawable/ic_favorite"
            android:tint="@color/color_text_secondary" />

        <!-- History icon -->
        <ImageView
            android:id="@+id/iv_history"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginStart="4dp"
            android:padding="6dp"
            android:src="@drawable/ic_history"
            android:tint="@color/color_text_secondary" />
    </LinearLayout>

    <!-- Category tabs -->
    <com.google.android.material.tabs.TabLayout
        android:id="@+id/tab_layout"
        android:layout_width="match_parent"
        android:layout_height="44dp"
        android:background="@color/color_bg_primary"
        app:tabGravity="start"
        app:tabMode="scrollable"
        app:tabSelectedTextColor="@color/color_primary"
        app:tabTextColor="@color/color_text_secondary"
        app:tabIndicatorColor="@color/color_primary"
        app:tabIndicatorHeight="2dp"
        app:tabTextAppearance="@style/TabTextStyle"
        app:tabPaddingStart="8dp"
        app:tabPaddingEnd="8dp"
        app:tabRippleColor="@android:color/transparent" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/color_divider" />

    <!-- Content: ViewPager2 with grid fragments -->
    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/view_pager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:background="@color/color_bg_secondary" />

</LinearLayout>
