<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_bg_primary"
    android:orientation="vertical">

    <!-- Video player container (portrait: ~56vw height) -->
    <FrameLayout
        android:id="@+id/fl_player_container"
        android:layout_width="match_parent"
        android:layout_height="210dp"
        android:background="@color/color_FF000000">

        <!-- Player view injected here -->

        <!-- Top bar overlay (back + title + time) -->
        <LinearLayout
            android:id="@+id/ll_top_bar"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:background="@drawable/gradient_top_dark"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="8dp"
            android:paddingEnd="12dp"
            android:visibility="visible">

            <ImageView
                android:id="@+id/iv_back"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:padding="8dp"
                android:src="@drawable/ic_arrow_back"
                android:tint="@color/color_text_white" />

            <TextView
                android:id="@+id/tv_video_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:ellipsize="end"
                android:maxLines="1"
                android:textColor="@color/color_text_white"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tv_time"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textColor="@color/color_text_white"
                android:textSize="12sp" />
        </LinearLayout>

        <!-- Loading indicator -->
        <ProgressBar
            android:id="@+id/pb_loading"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_gravity="center"
            android:indeterminateTint="@color/color_text_white"
            android:visibility="gone" />

        <!-- Bottom controls overlay -->
        <LinearLayout
            android:id="@+id/ll_bottom_controls"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom"
            android:background="@drawable/gradient_bottom_dark"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingBottom="8dp"
            android:paddingTop="24dp"
            android:visibility="visible">

            <!-- Play/Pause -->
            <ImageView
                android:id="@+id/iv_play_pause"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:src="@drawable/ic_pause"
                android:tint="@color/color_text_white" />

            <!-- Retry -->
            <ImageView
                android:id="@+id/iv_retry"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_refresh"
                android:tint="@color/color_text_white" />

            <View
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <!-- Fullscreen toggle -->
            <ImageView
                android:id="@+id/iv_fullscreen"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@drawable/ic_fullscreen"
                android:tint="@color/color_text_white" />
        </LinearLayout>
    </FrameLayout>

    <!-- Scrollable detail content -->
    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:scrollbars="none">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingBottom="24dp">

            <!-- Title card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/color_bg_primary"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="14dp">

                <!-- Title row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:id="@+id/tv_title"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:textColor="@color/color_text_primary"
                        android:textSize="18sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_detail_link"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:text="详情 >>"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Source + action row -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:layout_marginTop="10dp"
                    android:orientation="horizontal">

                    <!-- Source chip -->
                    <LinearLayout
                        android:id="@+id/ll_source_chip"
                        android:layout_width="wrap_content"
                        android:layout_height="32dp"
                        android:background="@drawable/bg_chip"
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:paddingStart="10dp"
                        android:paddingEnd="10dp">

                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="来源："
                            android:textColor="@color/color_text_secondary"
                            android:textSize="12sp" />

                        <TextView
                            android:id="@+id/tv_source_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:maxWidth="100dp"
                            android:ellipsize="end"
                            android:maxLines="1"
                            android:textColor="@color/color_text_primary"
                            android:textSize="12sp" />

                        <ImageView
                            android:id="@+id/iv_refresh_source"
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:layout_marginStart="4dp"
                            android:src="@drawable/ic_refresh"
                            android:tint="@color/color_text_secondary" />
                    </LinearLayout>

                    <View android:layout_width="0dp" android:layout_height="1dp" android:layout_weight="1" />

                    <!-- Action buttons: cast | collect | download -->
                    <ImageView
                        android:id="@+id/iv_cast"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_cast"
                        android:tint="@color/color_text_secondary" />

                    <View android:layout_width="1dp" android:layout_height="20dp"
                        android:layout_marginStart="14dp" android:layout_marginEnd="14dp"
                        android:background="@color/color_border" />

                    <ImageView
                        android:id="@+id/iv_collect"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_favorite_border"
                        android:tint="@color/color_text_secondary" />

                    <View android:layout_width="1dp" android:layout_height="20dp"
                        android:layout_marginStart="14dp" android:layout_marginEnd="14dp"
                        android:background="@color/color_border" />

                    <ImageView
                        android:id="@+id/iv_download"
                        android:layout_width="28dp"
                        android:layout_height="28dp"
                        android:src="@drawable/ic_download"
                        android:tint="@color/color_text_secondary" />
                </LinearLayout>
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="8dp"
                android:background="@color/color_bg_secondary" />

            <!-- Route section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/color_bg_primary"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="线路"
                        android:textColor="@color/color_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_fast_switch"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:drawableEnd="@drawable/ic_refresh"
                        android:drawableTint="@color/color_text_secondary"
                        android:gravity="center_vertical"
                        android:text="快捷换线"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Route tab list (horizontal scroll) -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_routes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:scrollbars="none" />
            </LinearLayout>

            <View android:layout_width="match_parent" android:layout_height="8dp"
                android:background="@color/color_bg_secondary" />

            <!-- Episode section -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@color/color_bg_primary"
                android:orientation="vertical"
                android:paddingStart="16dp"
                android:paddingEnd="16dp"
                android:paddingTop="14dp"
                android:paddingBottom="14dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="选集"
                        android:textColor="@color/color_text_primary"
                        android:textSize="15sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_sort_toggle"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="倒序"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="13sp" />

                    <View android:layout_width="1dp" android:layout_height="16dp"
                        android:layout_marginStart="10dp" android:layout_marginEnd="10dp"
                        android:background="@color/color_border" />

                    <TextView
                        android:id="@+id/tv_episode_all"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="全部"
                        android:textColor="@color/color_text_secondary"
                        android:textSize="13sp" />
                </LinearLayout>

                <!-- Episodes grid -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_episodes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:scrollbars="none"
                    android:nestedScrollingEnabled="false" />
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

</LinearLayout>
